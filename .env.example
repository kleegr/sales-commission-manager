# ---------------------------------------------------------------------------
# Commission Manager — environment variables
# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your Neon connection string.
# On Vercel, set the same variable in Project → Settings → Environment Variables
# (the Neon/Vercel-Postgres integration usually sets DATABASE_URL for you).
#
# The app/API reads the FIRST of these that is present, in this order:
#   DATABASE_URL, POSTGRES_URL, DATABASE_URL_UNPOOLED,
#   POSTGRES_PRISMA_URL, POSTGRES_URL_NON_POOLING, NEON_DATABASE_URL
# ---------------------------------------------------------------------------

# Neon pooled connection string (recommended for serverless).
DATABASE_URL="postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Optional: direct (unpooled) connection, used by some tools/migrations.
# DATABASE_URL_UNPOOLED="postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ---------------------------------------------------------------------------
# DEMO / REVIEW MODE
# ---------------------------------------------------------------------------
# When demo mode is ON, the app can be reviewed WITHOUT logging in: a top
# "Review Mode" bar lets you switch tenant (Demo / Acme) and role (Agency Owner,
# Sub-account Admin, Sales Manager, Salesperson, Affiliate/Partner). The bypass
# only ever assumes the identity of an existing seeded demo user — it never
# invents credentials, and a real password session always takes precedence.
#
# Demo mode is ON BY DEFAULT. To require real login (production / real data),
# set this to off (also accepts 0, false, disabled, no):
#
#   *** TURN THIS OFF BEFORE PUTTING REAL CUSTOMER DATA IN THE APP ***
#
# DEMO_MODE="off"

# ---------------------------------------------------------------------------
# KLEEGR SMART PRODUCTIVITY INTEGRATION (server-side only)
# ---------------------------------------------------------------------------
# This app integrates with GoHighLevel ONLY through Kleegr Smart Productivity.
# These are read SERVER-SIDE only — never expose them to the browser, never put
# them in the manifest, and never commit real values. On Vercel they are already
# configured for Production and Preview (set the same names locally to test).
#
# Base URL of the Kleegr Smart Productivity API.
KLEEGR_API_BASE_URL="https://smart-productivity-pied.vercel.app"
#
# Long-lived server↔Kleegr credential (token verification, status reporting,
# manifest dry-run). Used as: Authorization: Bearer ${KLEEGR_INTEGRATION_TOKEN}
KLEEGR_INTEGRATION_TOKEN="set-in-vercel-do-not-commit"
#
# Shared secret used to verify inbound webhook signatures (HMAC-SHA256 over the
# raw body, sent by Kleegr as the X-SP-Signature header).
KLEEGR_WEBHOOK_SECRET="set-in-vercel-do-not-commit"
