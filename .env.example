# ---------------------------------------------------------------------------
# Commission Manager — environment variables
# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your Neon connection string.
# On Vercel, set the same variable in Project → Settings → Environment Variables
# (the Neon/Vercel-Postgres integration usually sets DATABASE_URL for you).
#
# The app/API reads the FIRST of these that is present, in this order:
#   DATABASE_URL, POSTGRES_URL, DATABASE_URL_UNPOOLED,
#   POSTGRES_PRISMA_URL, POSTGRES_URL_NON_POOLING, NEON_DATABASE_URL
# ---------------------------------------------------------------------------

# Neon pooled connection string (recommended for serverless).
DATABASE_URL="postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Optional: direct (unpooled) connection, used by some tools/migrations.
# DATABASE_URL_UNPOOLED="postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require"
